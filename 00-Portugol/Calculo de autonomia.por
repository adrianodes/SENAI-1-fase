programa {
  funcao inicio() {
    // informações
    inteiro km
    real litros, kml
    // entradas
    escreva("Digite a kilometragem: Km")
    leia(km)
    escreva("Digite litros gastos: ")
    leia(litros)
    // processamentos
    kml = km / litros
    // saídas
    escreva("Consumo médio: Km/l " + kml)

  }
}
