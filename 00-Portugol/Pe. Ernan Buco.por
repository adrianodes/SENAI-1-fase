programa {
  funcao inicio() {
  real custosMensais = 2753.91, valoresRecebidos = 3981.52, diferencaCustos
    // calculos
    diferencaCustos = custosMensais - valoresRecebidos
    // apresentação
    escreva("Controle de custos da igreja\n") 
    escreva("Custos mensais: " + custosMensais) 
    escreva("\nValores recebidos: " + valoresRecebidos)
    escreva("\nDiferença de caixa: " + diferencaCustos)
    
  }
}
