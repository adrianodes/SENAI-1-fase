programa {
  real brutoTotal = 6579.00, premiacoes = 112.00, presentes = 750.00, comicoes = 650.00
    //real lucro
    real gastos = premiacoes + presentes + comicoes
    real lucro = brutoTotal - gastos
    escreva("Calculo lucro")
    escreva("\nTotal bruto: R$" + brutoTotal)
    escreva("\nGastos: R$" + gastos)
    escreva("\nLucro Total: R$" + lucro)
    
  }
}
