programa {
  funcao inicio() {
    inteiro qtdInicialLaranjas = 60, qtdFinalLaranjas = 25, qtdLaranjasVendidas
    // calculos
    qtdLaranjasVendidas = qtdInicialLaranjas - qtdFinalLaranjas
    // apresentação 
    escreva("Controle de estoque\n")
    escreva("Quantidade inicial de laranjas: " + qtdInicialLaranjas)
    escreva("\nQuantidade final de laranjas: "+ qtdFinalLaranjas)
    escreva("\nQuantidade de laranjas vendidas: "+ qtdLaranjasVendidas)
  }
}
