programa {
  funcao inicio() {
    real a, b, c, media
    // declara valores
    escreva("Média A: ")
    leia(a)
    escreva("Média B: ")
    leia(b)
    escreva("Média C: ")
    leia(c)
    // calculos
    media = (a * 2 + b * 3 + c * 5) / 10
    // apresentações
    escreva("Média: " + media) 

  }
}
