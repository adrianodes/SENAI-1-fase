programa {
  funcao inicio() {
    inteiro precoDoPar, numeroPares
    // inteiro valeTrocas
    escreva("Preço por par: ")
    leia(precoDoPar)
    escreva("Quantidade de pares: ")
    leia(numeroPares)
    inteiro valeTrocas = precoDoPar * numeroPares
    escreva("Total vale trocas: " + valeTrocas)

  }
}
